<?xml version="1.0" encoding="utf-8"?>
<!--
    LAYOUT ITEM : item_film.xml (un élément de la liste des films)

    Ce layout est utilisé par FilmAdapter.getView() pour afficher chaque film
    dans la ListView de ListefilmsActivity.

    Structure de la carte :
    ConstraintLayout (carte blanche avec ombre)
     ├── TextView tvTitreFilm (titre en gras, grande taille, à gauche)
     ├── TextView tvRealisateurFilm (réalisateur en gris, sous le titre)
     ├── TextView tvAnneeFilm (année en gris petit, sous le réalisateur)
     └── Button btnAjouterPanierItem (à droite, centré verticalement)

    Le titre, réalisateur et année sont contraints à gauche du bouton
    (layout_constraintEnd_toStartOf="@id/btnAjouterPanierItem")
    pour éviter qu'ils ne se superposent.

    android:elevation="2dp" : légère ombre pour l'effet "carte" Material Design.
    android:layout_marginBottom="8dp" : espace entre les cartes dans la liste.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/white"
    android:elevation="2dp"
    android:layout_marginBottom="8dp">

    <!--
        Titre du film (gras, grand)
        Rempli via : tvTitre.setText(film.getTitre())
        0dp en largeur + contraintes = s'étend entre le bord gauche et le bouton
    -->
    <TextView
        android:id="@+id/tvTitreFilm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Titre du film"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAjouterPanierItem"
        android:layout_marginEnd="8dp"/>

    <!--
        Nom du réalisateur (gris, taille moyenne)
        Rempli via : tvRealisateur.setText(film.getRealisateur())
        Positionné juste sous le titre.
    -->
    <TextView
        android:id="@+id/tvRealisateurFilm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Réalisateur"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/tvTitreFilm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAjouterPanierItem"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"/>

    <!--
        Année de sortie (gris, petite taille)
        Rempli via : tvAnnee.setText(String.valueOf(film.getAnnee()))
        Positionné sous le réalisateur.
    -->
    <TextView
        android:id="@+id/tvAnneeFilm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="2024"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/tvRealisateurFilm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAjouterPanierItem"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"/>

    <!--
        Bouton "Ajouter au panier" positionné à droite de la carte.
        Centré verticalement par rapport à la carte entière
        (constraintTop_toTopOf="parent" + constraintBottom_toBottomOf="parent").
        Son gestionnaire est défini dans FilmAdapter.getView() :
        btnAjouterPanier.setOnClickListener(...) appelle AddToCartTask.
        Petit padding pour réduire sa taille sur la carte.
    -->
    <Button
        android:id="@+id/btnAjouterPanierItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ajouter au panier"
        android:textSize="11sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

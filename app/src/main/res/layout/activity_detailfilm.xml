<?xml version="1.0" encoding="utf-8"?>
<!--
    LAYOUT : activity_detailfilm.xml (écran de détail d'un film)

    Structure de la vue :
    ConstraintLayout (racine, fond gris)
     ├── ConstraintLayout topBar (barre supérieure blanche, hauteur fixe 56dp)
     │    ├── Button "◀ Retour"
     │    └── TextView "Détail du film"
     ├── ProgressBar (barre de chargement horizontale, sous la topBar)
     └── ScrollView (zone de défilement pour le contenu)
          └── ConstraintLayout (contenu scrollable)
               ├── TextView tvTitreFilmDetail (grand titre du film)
               ├── TextView tvInfosFilm (année • durée • classification)
               ├── TextView "Synopsis" (label) + TextView tvDescription
               ├── TextView "Langue originale" + TextView tvLangue
               ├── TextView "Réalisateurs" (label) + TextView tvRealisateurs
               ├── TextView "Acteurs" (label) + TextView tvActeurs
               ├── TextView "Catégories" (label) + TextView tvCategories
               └── Button "Ajouter au panier"

    ScrollView est nécessaire car le contenu (synopsis, liste acteurs, etc.)
    peut dépasser la hauteur de l'écran.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Barre supérieure avec bouton retour -->
    <!--
        Barre de navigation fixe en haut (ne défile pas avec le contenu).
        android:elevation="4dp" : ombre pour la faire ressortir visuellement.
        android:layout_height="56dp" : hauteur standard d'une barre d'action Android (ActionBar).
    -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            Bouton "◀ Retour" : ferme DetailfilmActivity et revient à ListefilmsActivity.
            Le gestionnaire est défini dans DetailfilmActivity.onCreate() :
            btnRetour.setOnClickListener(v -> finish())
        -->
        <Button
            android:id="@+id/btnRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀ Retour"
            android:textSize="14sp"
            android:textColor="@android:color/holo_blue_dark"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp"/>

        <!-- Titre "Détail du film" centré dans la barre -->
        <TextView
            android:id="@+id/tvTitreBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Détail du film"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnRetour"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="48dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--
        Barre de progression horizontale.
        style="progressBarStyleHorizontal" = barre horizontale qui avance (pas le cercle)
        Affiché juste sous la barre de navigation pendant le chargement du film.
        Controlée par DetailfilmActivity.showProgressBar()
    -->
    <ProgressBar
        android:id="@+id/progressBarDetail"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@android:color/holo_red_dark"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--
        Zone de défilement vertical.
        Prend toute la hauteur restante (0dp entre progressBar et bas de l'écran).
        Permet de défiler quand le contenu (synopsis, liste d'acteurs) est trop long.
    -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/progressBarDetail"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Contenu scrollable avec padding de 16dp -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!--
                Titre du film (grand, gras)
                Rempli par DetailfilmActivity.mettreAJourActivityAvecFilm() :
                tvTitreFilmDetail.setText(film.getTitre())
            -->
            <TextView
                android:id="@+id/tvTitreFilmDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Titre du film"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>

            <!--
                Informations résumées : année • durée • classification
                Exemple affiché : "2006 • 1h26 • PG"
                Couleur grise pour différencier des sections plus importantes
            -->
            <TextView
                android:id="@+id/tvInfosFilm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2006 • 1h26 • PG"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                app:layout_constraintTop_toBottomOf="@id/tvTitreFilmDetail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"/>

            <!-- Label de section "Synopsis" -->
            <TextView
                android:id="@+id/tvDescriptionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Synopsis"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvInfosFilm"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="24dp"/>

            <!-- Texte du synopsis/description du film -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Description du film"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvDescriptionLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Label "Langue originale:" sur la même ligne que la valeur -->
            <TextView
                android:id="@+id/tvLangueLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Langue originale:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvDescription"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="16dp"/>

            <!--
                Valeur de la langue originale (ex: "Anglais", "Français")
                Positionné à droite du label via layout_constraintStart_toEndOf
            -->
            <TextView
                android:id="@+id/tvLangue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Anglais"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvDescription"
                app:layout_constraintStart_toEndOf="@id/tvLangueLabel"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"/>

            <!-- Label de section "Réalisateurs" -->
            <TextView
                android:id="@+id/tvRealisateursLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Réalisateurs"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvLangueLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>

            <!--
                Liste des réalisateurs sous forme de texte multi-lignes
                Exemple : "• John Ford\n• Orson Welles"
                Le \n crée un retour à la ligne entre chaque réalisateur
            -->
            <TextView
                android:id="@+id/tvRealisateurs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Liste des réalisateurs"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvRealisateursLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Label de section "Acteurs" -->
            <TextView
                android:id="@+id/tvActeursLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Acteurs"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvRealisateurs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>

            <!-- Liste des acteurs sous forme de texte multi-lignes -->
            <TextView
                android:id="@+id/tvActeurs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Liste des acteurs"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvActeursLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Label de section "Catégories" -->
            <TextView
                android:id="@+id/tvCategoriesLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Catégories"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvActeurs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>

            <!-- Liste des catégories/genres sous forme de texte multi-lignes -->
            <TextView
                android:id="@+id/tvCategories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Liste des catégories"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toBottomOf="@id/tvCategoriesLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>

            <!--
                Bouton "Ajouter au panier" en bas du contenu scrollable.
                Son gestionnaire est dans DetailfilmActivity.onCreate() :
                btnAjouterPanier.setOnClickListener(...) appelle AddToCartTask.
                android:backgroundTint="holo_blue_dark" : couleur bleue du bouton
                android:layout_marginBottom="24dp" : espace en bas pour ne pas coller au bord
            -->
            <Button
                android:id="@+id/btnAjouterPanier"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Ajouter au panier"
                android:textSize="16sp"
                android:padding="16dp"
                android:backgroundTint="@android:color/holo_blue_dark"
                android:textColor="@android:color/white"
                app:layout_constraintTop_toBottomOf="@id/tvCategories"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
